{
  "name": "storybook-addon-twig",
  "version": "0.1.5",
  "author": "Gabriel Hamalwa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielhamalwa/storybook-addon-twig.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/icons": "^2.0.0",
    "@storybook/react-vite": "^10.3.0",
    "@types/node": "^20.19.0",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^10.3.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.0.5",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "storybook": "^10.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "default": "./dist/preview.js"
    },
    "./preview.js": "./preview.js",
    "./manager": "./dist/manager.js",
    "./manager.js": "./manager.js",
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js",
      "default": "./dist/preset.js"
    },
    "./preset.js": "./preset.js",
    "./package.json": "./package.json"
  },
  "bugs": {
    "url": "https://github.com/gabrielhamalwa/storybook-addon-twig/issues"
  },
  "bundler": {
    "exportEntries": [
      "src/index.ts"
    ],
    "managerEntries": [
      "src/manager.tsx"
    ],
    "previewEntries": [
      "src/preview.ts"
    ],
    "nodeEntries": [
      "src/preset.ts"
    ]
  },
  "description": "Twig source, code, and docs support for Storybook.",
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "manager.js",
    "preview.js",
    "preset.js"
  ],
  "homepage": "https://github.com/gabrielhamalwa/storybook-addon-twig#readme",
  "keywords": [
    "storybook-addon",
    "code",
    "twig",
    "source",
    "syntax-highlighting",
    "template",
    "html"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('./dist', { recursive: true, force: true })\"",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "check:package": "node scripts/check-package.mjs",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit"
  },
  "storybook": {
    "displayName": "Twig",
    "supportedFrameworks": [
      "react",
      "vue",
      "angular",
      "web-components",
      "ember",
      "html",
      "svelte",
      "preact"
    ],
    "preset": "./dist/preset.js"
  },
  "type": "module",
  "types": "dist/index.d.ts"
}
